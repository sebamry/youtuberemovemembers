{
  "manifest_version": 3,
  "name": "Members Only Filter",
  "version": "1.0.0",
  "description": "Hide members-only videos and member-only shelves across YouTube channel pages, home, recommendations, search, and subscriptions.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage"],
  "host_permissions": ["https://www.youtube.com/*"],
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content/main.js"],
      "css": ["content/main.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Members Only Filter",
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "options_page": "options/index.html"
}
